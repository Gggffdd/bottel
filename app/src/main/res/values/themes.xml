<resources>
    <!-- Светлая тема -->
    <style name="Theme.Messenger" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/telegram_blue</item>
        <item name="colorPrimaryVariant">@color/telegram_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/telegram_blue</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/gray_text</item>
        <item name="android:editTextColor">@color/black</item>
        <item name="android:textColorHint">@color/gray_text</item>
        <item name="colorControlNormal">@color/telegram_blue</item>
        <item name="colorControlActivated">@color/telegram_blue</item>
        <item name="colorControlHighlight">@color/gray_light</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
    </style>

    <!-- Тёмная тема -->
    <style name="Theme.Messenger.Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/telegram_blue</item>
        <item name="colorPrimaryVariant">@color/telegram_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/telegram_blue</item>
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:textColor">@color/dark_text</item>
        <item name="android:textColorPrimary">@color/dark_text</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
        <item name="android:editTextColor">@color/dark_text</item>
        <item name="android:textColorHint">@color/dark_text_secondary</item>
        <item name="colorControlNormal">@color/telegram_blue</item>
        <item name="colorControlActivated">@color/telegram_blue</item>
        <item name="colorControlHighlight">@color/gray_light</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
    </style>

    <style name="Theme.Messenger.Transparent" parent="Theme.Messenger">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
</resources>
