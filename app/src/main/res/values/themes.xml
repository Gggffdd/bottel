<resources>
    <!-- Светлая тема -->
    <style name="Theme.Messenger" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#3399ff</item>
        <item name="colorPrimaryVariant">#2b89d6</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#3399ff</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/gray_text</item>
        <item name="android:editTextColor">@color/black</item>
        <item name="android:textColorHint">@color/gray_text</item>
        <item name="colorControlNormal">@color/telegram_blue</item>
        <item name="colorControlActivated">@color/telegram_blue</item>
        <item name="colorControlHighlight">@color/gray_light</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
    </style>

    <!-- Тёмная тема -->
    <style name="Theme.Messenger.Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#3399ff</item>
        <item name="colorPrimaryVariant">#2b89d6</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#3399ff</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:colorBackground">@color/black</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/gray_text</item>
        <item name="android:editTextColor">@color/white</item>
        <item name="android:textColorHint">@color/gray_text</item>
        <item name="colorControlNormal">@color/telegram_blue</item>
        <item name="colorControlActivated">@color/telegram_blue</item>
        <item name="colorControlHighlight">@color/gray_light</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
        <item name="android:colorBackground">@color/black</item>
        <item name="android:colorPrimaryDark">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>

    <style name="Theme.Messenger.Transparent" parent="Theme.Messenger">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
</resources>
